# --- NationTwin AI Environment Configurations ---

# App Name
PROJECT_NAME="NationTwin AI"

# Backend FastAPI Settings
API_V1_STR="/api/v1"
UPDATE_INTERVAL_SECONDS=5

# Toggle Mock Mode (True by default for out-of-the-box operation)
MOCK_MODE=true

# Google Gemini API key (for live multi-agent LLM consensus calculations)
GEMINI_API_KEY=""

# PostgreSQL Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nationtwin

# Redis Cache Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Neo4j Graph DB Settings
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Frontend Next.js Settings
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
